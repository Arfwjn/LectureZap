{
  // Disable VS Code's built-in CSS validator — it doesn't understand
  // Tailwind CSS v4 syntax like `@import 'tailwindcss' source(none)`,
  // `@source`, `@theme`, `@custom-variant`, etc.
  // Tailwind CSS IntelliSense extension handles validation instead.
  "css.validate": false,
  "scss.validate": false,

  // Tell the Tailwind IntelliSense extension which files contain Tailwind CSS
  "tailwindCSS.includeLanguages": {
    "typescriptreact": "html",
    "javascriptreact": "html"
  },

  // Trigger Tailwind completions inside className strings
  "editor.quickSuggestions": {
    "strings": "on"
  }
}
