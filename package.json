{
  "name": "lecturezap",
  "version": "1.0.0",
  "private": true,
  "description": "LectureZap — Smart Academic AI Platform",
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "dev:all": "concurrently \"npm run dev:server\" \"npm run dev\"",
    "build": "npm run build --workspace=client",
    "build:server": "npm run build --workspace=server",
    "build:all": "npm run build --workspace=shared && npm run build:server && npm run build",
    "type-check": "npm run type-check --workspace=client && npm run type-check --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
